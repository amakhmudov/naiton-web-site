---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import db from "../data/db.json";

const { phone } = db.contact;
---

<Layout
  title="Contact Naiton | Rotterdam, Netherlands"
  description="Get in touch with Naiton. Call us or visit our office at Kurt Callostraat 19, 3067 CZ Rotterdam, Netherlands. We'd love to give you a free demo."
>
  <div class="container">
    <div class="px-4 py-9 text-white bg-accent flex items-center justify-between">
      <p class="h2 text-white">Contact</p>

      <ul class="breadcrumbs">
        <li><a href="/">Home</a></li>
        <li><span>Contact</span></li>
      </ul>
    </div>
  </div>

  <div data-lazy>
    <section class="container py-12">
      <ul class="flex max-lg:flex-col max-lg:space-y-6 items-start justify-center">
        <li class="lg:px-12">
          <a
            href={`tel:${phone}`}
            class="flex lg:flex-col md:text-center items-center lg:space-y-3 max-lg:space-x-3"
          >
            <span class="text-accent size-9 shrink-0 flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                width="36"
                height="36"
                fill="none"
              >
                <path
                  d="M7.93376 1.67243C7.65948 1.65248 7.37845 1.68051 7.10286 1.76195L6.11654 2.05411C5.06551 2.36494 4.24431 3.19885 3.96647 4.25137C3.34956 6.5921 4.05528 9.36269 5.89193 12.4814C7.72599 15.5957 9.81584 17.575 12.1761 18.2211C13.239 18.512 14.3853 18.2341 15.1904 17.4862L15.9408 16.7904C16.7803 16.0109 16.9055 14.7125 16.2272 13.7899L15.1432 12.3178C14.5622 11.5285 13.5379 11.1925 12.596 11.4755L10.9001 11.9833C10.8289 12.0041 10.6585 11.9071 10.5103 11.779L10.5094 11.7782C10.2454 11.5486 9.87953 11.0845 9.48812 10.4208V10.42C9.06842 9.70719 8.88941 9.24102 8.81754 8.96573C8.74564 8.69031 8.76309 8.65681 8.7736 8.56371C8.77906 8.51726 8.80113 8.47422 8.8387 8.44001L8.83952 8.4392L10.1042 7.28279C10.8287 6.62043 11.0474 5.56195 10.6388 4.6713L9.8763 3.00788V3.00707C9.5173 2.22453 8.75636 1.73228 7.93376 1.67243ZM7.84342 2.91918C8.22601 2.94776 8.5783 3.17725 8.73942 3.52872L9.50277 5.19213C9.6875 5.59481 9.59486 6.0556 9.26107 6.36075L7.99642 7.51635C7.73716 7.75273 7.57137 8.07502 7.53174 8.42292V8.42374C7.52141 8.51522 7.49701 8.85545 7.60824 9.28148C7.71946 9.70752 7.94909 10.271 8.41064 11.0548H8.41146C8.84212 11.7852 9.24914 12.3401 9.68994 12.7231H9.69075C9.83391 12.847 10.4339 13.422 11.25 13.1837L11.2524 13.1829L12.9557 12.6726C13.398 12.5397 13.8709 12.6984 14.1366 13.0592L15.2205 14.5313C15.5275 14.9495 15.4739 15.518 15.0903 15.8741L14.34 16.5707C13.8601 17.0167 13.1476 17.1907 12.5057 17.015C10.5976 16.4928 8.7095 14.8022 6.9694 11.8474C5.22688 8.88856 4.68187 6.44132 5.17497 4.57038C5.33796 3.9529 5.83737 3.44034 6.47135 3.25284L7.45687 2.96068C7.58524 2.92275 7.7159 2.90965 7.84342 2.91918Z"
                  fill="currentColor"></path>
              </svg>
            </span>
            <span class="h3">020&nbsp;893&nbsp;2732</span>
          </a>
        </li>

        <li class="lg:px-12">
          <span
            class="flex lg:flex-col md:text-center items-center lg:space-y-3 max-lg:space-x-3"
          >
            <span class="text-accent size-9 shrink-0 flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 16 18"
                width="36"
                height="36"
                fill="none"
              >
                <path
                  fill="currentColor"
                  d="M8 .667C4.095.667.917 3.846.917 7.75a7.06 7.06 0 0 0 1.699 4.596l.003.004.003.003s3.013 3.438 4.086 4.462a1.881 1.881 0 0 0 2.583 0c1.223-1.166 4.088-4.464 4.088-4.464l.002-.002.002-.003a7.055 7.055 0 0 0 1.7-4.596C15.083 3.846 11.904.667 8 .667Zm0 1.25a5.824 5.824 0 0 1 5.833 5.833 5.792 5.792 0 0 1-1.4 3.784c-.006.007-2.937 3.36-4.004 4.377a.61.61 0 0 1-.859 0c-.891-.851-3.995-4.367-4.004-4.377a5.796 5.796 0 0 1-1.4-3.784A5.824 5.824 0 0 1 8 1.917ZM8 5.25c-.781 0-1.446.315-1.873.796A2.554 2.554 0 0 0 5.5 7.75c0 .608.2 1.224.627 1.704s1.092.796 1.873.796c.781 0 1.446-.315 1.873-.796.427-.48.627-1.096.627-1.704 0-.608-.2-1.224-.627-1.704S8.781 5.25 8 5.25ZM8 6.5c.469 0 .741.153.94.376.197.223.31.544.31.874 0 .33-.113.651-.31.874C8.74 8.847 8.468 9 8 9s-.741-.153-.94-.376a1.33 1.33 0 0 1-.31-.874c0-.33.113-.651.31-.874.199-.223.471-.376.94-.376Z"
                ></path>
              </svg>
            </span>
            <span class="h3">Kurt Callostraat 19 3067 CZ, Rotterdam Netherlands</span>
          </span>
        </li>
      </ul>
    </section>
  </div>

  <div data-lazy>
    <section class="section container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2459.6278302935148!2d4.547359477575084!3d51.940741678953025!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c5cd3112003f99%3A0x542fa7388ed22c0b!2sKurt%20Callostraat%2019%2C%203067%20CZ%20Rotterdam%2C%20Netherlands!5e0!3m2!1sen!2s!4v1697114422462!5m2!1sen!2s"
        width="100%"
        height="600"
        style="border:0"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Naiton address on Google Maps"></iframe>
    </section>
  </div>

  <div data-lazy>
    <section class="container">
      <CTASection title="Would you like to get acquainted with Nation Business Suite without obligation?" />
    </section>
  </div>
</Layout>
